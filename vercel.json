{
  "buildCommand": "npm run web:build",
  "outputDirectory": "web/out",
  "functions": {
    "api/public-search-cache.js": {
      "maxDuration": 5
    },
    "api/public-search-refresh.js": {
      "maxDuration": 5
    }
  },
  "crons": [
    {
      "path": "/api/public-search-refresh",
      "schedule": "0 */6 * * *"
    }
  ]
}
