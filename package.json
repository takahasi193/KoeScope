{
  "name": "koescope",
  "version": "0.1.0",
  "private": true,
  "description": "Local Bangumi voice actor work search and DLsite monitor helper.",
  "type": "module",
  "scripts": {
    "prestart": "node scripts/ensure-web-build.mjs",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test && npm run web:test",
    "web:build": "cd web && next build",
    "web:dev": "cd web && next dev",
    "web:test": "cd web && node --test --import tsx src/lib/*.test.ts"
  },
  "dependencies": {
    "@heroui/react": "^3.0.4",
    "@heroui/styles": "^3.0.4",
    "better-sqlite3": "^12.9.0",
    "chart.js": "^4.5.1",
    "cheerio": "^1.1.2",
    "express": "^5.1.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
