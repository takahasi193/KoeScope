{
  "manifest_version": 3,
  "name": "KoeScope Companion",
  "version": "0.1.0",
  "description": "Browser entry point for the local KoeScope backend.",
  "icons": {
    "16": "icons/koescope-icon-16.png",
    "32": "icons/koescope-icon-32.png",
    "48": "icons/koescope-icon-48.png",
    "128": "icons/koescope-icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "KoeScope",
    "default_icon": {
      "16": "icons/koescope-icon-16.png",
      "32": "icons/koescope-icon-32.png",
      "48": "icons/koescope-icon-48.png",
      "128": "icons/koescope-icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["contextMenus", "storage", "tabs", "scripting"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://dlsite.com/*",
    "https://*.dlsite.com/*"
  ]
}
